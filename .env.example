# PostgreSQL
DB_USER=hvostid
DB_PASSWORD=hvostid

# Demo seed (T42): set to "demo" to load Flyway seed data on backend startup.
# Used by ./scripts/seed-all.sh. Leave empty for production-like runs (CI/CD).
# SPRING_PROFILES_ACTIVE=demo

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_DOCUMENTS_BUCKET=pet-documents
MINIO_PHOTOS_BUCKET=pet-photos

# SonarQube (optional, for CI)
# SONAR_TOKEN=
# SONAR_HOST_URL=http://localhost:9090

{
    "name": "hvostid-frontend",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{js,jsx,css,html}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,css,html}\""
    },
    "dependencies": {
        "axios": "^1.16.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.15.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^5.7.7",
        "@eslint/js": "^10.0.1",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "lint-staged": "^17.0.3",
        "postcss": "^8.5.14",
        "prettier": "^3.8.3",
        "tailwindcss": "^3.4.17",
        "typescript": "^6.0.3",
        "vite": "^6.0.7"
    },
    "lint-staged": {
        "**/*.{js,jsx}": [
            "eslint --fix --no-warn-ignored",
            "prettier --write"
        ],
        "**/*.{css,html,json}": [
            "prettier --write"
        ]
    }
}

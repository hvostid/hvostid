# Image tag (matches GHCR tag pushed by T26)
IMAGE_TAG=latest

# GHCR owner (used by image: in docker-compose.prod.yml)
GHCR_OWNER=hvostid

# PostgreSQL credentials (do not use defaults)
DB_USER=hvostid
DB_PASSWORD=CHANGE_ME

# MinIO credentials (do not use defaults)
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_DOCUMENTS_BUCKET=pet-documents
MINIO_PHOTOS_BUCKET=pet-photos

# Public origins allowed for CORS on api-gateway
HVOSTID_CORS_ALLOWED_ORIGINS=http://localhost

# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Gradle wrapper
gradlew text eol=lf
*.bat text eol=crlf
*.jar binary

# Java
*.java text eol=lf
*.kts text eol=lf
*.properties text eol=lf

# Web / Frontend
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.conf text eol=lf
*.toml text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Shell
*.sh text eol=lf

# SQL
*.sql text eol=lf

# Markdown / Docs
*.md text eol=lf
*.txt text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Archives
*.zip binary
*.tar.gz binary
*.gz binary

# Lock files
package-lock.json text eol=lf -diff

{
  "info": {
    "_postman_id": "col-01-public-api",
    "name": "COL-01 Public API",
    "description": "Smoke test of the public-facing gateway routes: register a buyer, login, refresh, profile, list catalog, fetch by id. Run with the `hvostid-local` environment selected.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.code === 401 && pm.environment.get('refreshToken')) {",
          "    const baseUrl = pm.environment.get('baseUrl');",
          "    pm.sendRequest({",
          "        url: baseUrl + '/api/v1/auth/refresh',",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' },",
          "        body: { mode: 'raw', raw: JSON.stringify({ refreshToken: pm.environment.get('refreshToken') }) }",
          "    }, function (err, res) {",
          "        if (!err && res && res.code === 200) {",
          "            const data = res.json();",
          "            pm.environment.set('accessToken', data.accessToken);",
          "            pm.environment.set('refreshToken', data.refreshToken);",
          "            console.log('Auto-refreshed access token after 401');",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Register buyer",
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{buyerEmail}}\",\n    \"password\": \"{{buyerPassword}}\",\n    \"name\": \"{{buyerName}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register accepted (201) or already exists (409)', function () {",
              "    pm.expect([201, 409]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login (saves tokens)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{buyerEmail}}\",\n    \"password\": \"{{buyerPassword}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is JSON', () => pm.response.to.be.json);",
              "const data = pm.response.json();",
              "pm.test('Has accessToken / refreshToken', () => {",
              "    pm.expect(data.accessToken).to.be.a('string').and.not.empty;",
              "    pm.expect(data.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.environment.set('accessToken', data.accessToken);",
              "pm.environment.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh token",
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.environment.set('accessToken', data.accessToken);",
              "pm.environment.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get my profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/profile/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "profile", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.test('Profile has id and email', () => {",
              "    pm.expect(data.id).to.exist;",
              "    pm.expect(data.email).to.be.a('string');",
              "});",
              "if (data.id) { pm.environment.set('userId', data.id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "List published listings",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/listings?page=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "listings"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.test('Response has paginated shape', () => {",
              "    pm.expect(data).to.have.property('content');",
              "    pm.expect(data.content).to.be.an('array');",
              "    pm.expect(data).to.have.property('totalElements');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List with filters",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/listings?species=dog&priceMin=0&priceMax=50000&sort=created_desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "listings"],
          "query": [
            { "key": "species", "value": "dog" },
            { "key": "priceMin", "value": "0" },
            { "key": "priceMax", "value": "50000" },
            { "key": "sort", "value": "created_desc" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Get listing by id (404 expected for empty catalog)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/listings/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "listings", "1"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 404', function () {",
              "    pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
